# A well-behaved example/template config. Every secret-shaped value here is a
# placeholder or an environment reference, so keyhunt should report ZERO
# findings. This demo proves keyhunt does not cry wolf on good hygiene.

# Placeholders the scanner suppresses
DB_PASSWORD=changeme
ADMIN_PASSWORD=<password>
API_KEY=your_password
SMTP_PASS=placeholder

# Environment indirection (no literal secret present)
DATABASE_URL=postgres://app_user@db.internal:5432/appdb
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
GITHUB_TOKEN=$GITHUB_TOKEN
SLACK_WEBHOOK=https://hooks.example.com/services/T000/B000/xxxx

# Plain non-secret settings
LOG_LEVEL=info
FEATURE_FLAG_NEW_UI=true
REQUEST_TIMEOUT_SECONDS=30
